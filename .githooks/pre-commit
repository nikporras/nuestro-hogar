#!/usr/bin/env bash
# Local pre-commit secret guard (docs/THREAT_MODEL.md, I2).
# Uses gitleaks if installed; always runs a lightweight pattern fallback so the
# guard works even on machines without gitleaks. CI is the authoritative check.
set -euo pipefail

# 1) gitleaks, if available
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --redact --no-banner; then
    echo "✖ gitleaks found a potential secret in staged changes. Commit aborted." >&2
    exit 1
  fi
fi

# 2) lightweight fallback: scan staged additions for obvious key shapes
staged_diff="$(git diff --cached --no-color || true)"
patterns='sk-ant-[A-Za-z0-9_-]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----|xox[baprs]-[A-Za-z0-9-]{10,}'
if printf '%s' "$staged_diff" | grep -nE "^\+" | grep -Eq "$patterns"; then
  echo "✖ A value matching a known secret pattern is staged. Commit aborted." >&2
  echo "  Remove the secret, use an env var, and see .env.example." >&2
  exit 1
fi

# 3) Smoke test — parse-check + mock-runtime of the inline <script> so a
# syntax error or init-time throw can't slip past the local commit.
# CI re-runs the same script, but failing locally is much cheaper than
# failing in a PR.
if git diff --cached --name-only | grep -qE '(^|/)index\.html$'; then
  if command -v node >/dev/null 2>&1; then
    if ! node scripts/smoke.js > /tmp/olympaws-smoke.log 2>&1; then
      echo "✖ scripts/smoke.js failed — index.html doesn't parse / run cleanly. Output:" >&2
      cat /tmp/olympaws-smoke.log >&2
      exit 1
    fi
  else
    echo "⚠ node not installed locally; skipping smoke. CI will still run it." >&2
  fi
fi

exit 0
