# Nuestro Hogar — environment template
#
# These values are consumed ONLY by the Phase 2 serverless proxy (server-side).
# They must NEVER be referenced by the frontend / committed to the repo.
# Copy to `.env` (git-ignored) for local proxy development.

# Anthropic API key — lives only in the proxy's secret store / env.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Model and limits are enforced server-side so the client cannot override them.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=1000

# CORS allow-list for the proxy: the exact origin of the deployed PWA.
ALLOWED_ORIGIN=https://your-user.github.io

# Per-IP rate limit (requests per minute) and a daily request cap, to bound cost.
RATE_LIMIT_PER_MIN=10
DAILY_REQUEST_CAP=500
